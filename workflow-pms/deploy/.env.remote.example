# Copy to ~/workflow-pms/.env on the server (optional; docker-compose can use inline env)
DATABASE_URL=postgresql://workflow:workflow@postgres:5432/workflow_pms?schema=public
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
FILE_STORAGE_PATH=/data/uploads
CORS_ORIGIN=http://YOUR_PUBLIC_IP:8082,http://localhost:8082
